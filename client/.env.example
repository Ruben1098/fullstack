# SSR Server — Environment Configuration
# Copy to .env and fill in the values

# SSR server port (the public-facing website server)
PORT=3000

# Internal API URL (the Bun markdown API server)
API_URL=http://localhost:4001

# Raw API key (must match a key registered in api/.env API_KEYS)
# Generate: bun -e "console.log(crypto.randomUUID())"
API_KEY=your-raw-api-key-here

# Base URL for canonical links (leave empty in dev)
BASE_URL=

# Assets server (fonts, images)
ASSETS_URL=http://localhost:5001

# Page cache TTL in milliseconds (default 30 minutes)
CACHE_TTL_MS=1800000

# Optional: secret for POST /_cache/purge endpoint
PURGE_SECRET=change-me-in-production
