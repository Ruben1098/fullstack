{
	"name": "bun-react-template",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "src/index.tsx",
	"module": "src/index.tsx",
	"scripts": {
		"dev": "bun --hot src/index.tsx",
		"css": "postcss app/globals.css -o .framework/dev/globals.css -w",
		"css:build": "postcss app/globals.css -o .framework/dev/globals.css",
		"css:ssr": "postcss app/globals.css -o .framework/dev/globals.css",
		"start": "NODE_ENV=production bun src/index.tsx",
		"build": "bun run build.ts",
		"static:build": "bun server/static-render.ts",
		"server": "bun --hot server/index.ts",
		"server:start": "NODE_ENV=production bun server/index.ts"
	},
	"dependencies": {
		"@hookform/resolvers": "^4.1.0",
		"@radix-ui/react-label": "^2.1.2",
		"@radix-ui/react-select": "^2.1.6",
		"@radix-ui/react-slot": "^1.1.2",
		"@tailwindcss/cli": "^4.1.18",
		"@tailwindcss/postcss": "^4.1.18",
		"@tanstack/react-query": "^5.90.20",
		"@tanstack/react-router": "^1.157.2",
		"@types/react-katex": "^3.0.4",
		"autoprefixer": "^10.4.24",
		"bun-plugin-tailwind": "^0.0.14",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cssnano": "^7.1.2",
		"hono": "^4.11.5",
		"katex": "^0.16.44",
		"lucide-react": "^0.475.0",
		"postcss-cli": "^11.0.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-hook-form": "^7.54.2",
		"react-katex": "^3.1.0",
		"react-markdown": "^10.1.0",
		"remark-directive": "^4.0.0",
		"remark-gfm": "^4.0.1",
		"tailwind-merge": "^3.0.1",
		"tailwindcss": "^4.1.18",
		"tailwindcss-animate": "^1.0.7",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"postcss": "^8.5.6"
	}
}
