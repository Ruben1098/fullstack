# Environment Configuration
# Copy this file to .env and fill in the values

# Server
PORT=4001
NODE_ENV=development

# API Keys (JSON array of key configs)
# Generate a key: bun -e "console.log(crypto.randomUUID())"
# Hash it:        bun -e "const k='your-key'; console.log(await crypto.subtle.digest('SHA-256', new TextEncoder().encode(k)).then(b => Buffer.from(b).toString('hex')))"
# Format: [{"id":"key-1","hash":"<sha256-hex>","rateLimit":100},{"id":"key-2","hash":"<sha256-hex>"}]
API_KEYS=[{"id":"dev-key","hash":"3c9909afec25354d551dae21590bb26e38d53f2173b8d3dc3eee4c047e7ab1c1eb8b85103e3be7ba613b31bb5c9c36214dc9f14a42fd7a2fdb84856bca5c44c2","rateLimit":200}]

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cache
CACHE_TTL_MS=1800000
CACHE_MAX_SIZE=1000

# Body size limit in bytes (default 1MB)
BODY_LIMIT=1048576

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Content path (relative to api/ root, points to compiled client contents)
CONTENTS_PATH=../client/constants/contents.json
